DATABASE_URL=mysql://username:password@localhost:3306/laravel_passport
# DATABASE_URL=postgresql://username:password@localhost:5432/laravel_passport
# DATABASE_URL="fake"
DATABASE_MIN_CONNECTIONS=10
DATABASE_MAX_CONNECTIONS=100

GATEWAY_SECRET=your-super-secret-gateway-key

# JWT Public Key (the public key from Laravel Passport)
# Get this from your Laravel app: cat storage/oauth-public.key
JWT_PUBLIC_KEY=
# or
JWT_PUBLIC_KEY_PATH=

JWT_ALGORITHM=RS256

# same as NUXT_OAUTH_OIDC_CLIENT_ID for example
# UUID from `php artisan passport:client`
# use if you want to validate token `aud`
# to differ resource servers use X-Client-Id header on gateway/proxy instead
# Optional
CLIENT_ID=

SERVER_PORT=8080
# probably for container
SERVER_HOST=0.0.0.0
# or for local proxy
SERVER_HOST=127.0.0.1
# or IPv6
SERVER_HOST=[::1]
# IPv6 wildcard with IPv4
SERVER_HOST=::
SOCKET_PATH=/tmp/introspector.sock

TOKEN_CACHE_SIZE=1000
TOKEN_CACHE_TTL=60

# MONO_PROXY_TARGET=http://localhost
MONO_PROXY_TARGET=http://127.0.0.1
